# Archivo de variables de entorno (Template)
# Copia este archivo como '.env.local' y reemplaza los valores con tus credenciales.

# GROQ API KEY: Usada para el chat interactivo de Blado
# Puedes obtener una en: https://console.groq.com/keys
GROQ_API_KEY=gsk_aqui_va_tu_api_key_de_groq

# ─── Supabase / Prisma ────────────────────────────────────────────────────────
# DATABASE_URL: Connection string con pooler (para Vercel/Serverless)
# Obtenerla en: Supabase Dashboard → Settings → Database → Transaction pooler URI
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL: Conexión directa (necesaria para ejecutar migraciones con prisma migrate)
# Obtenerla en: Supabase Dashboard → Settings → Database → Direct connection URI
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"
