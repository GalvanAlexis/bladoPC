// Prisma Schema — Portfolio Blado
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Modelos ─────────────────────────────────────────────────────────────────

model Visitor {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  lastSeenAt   DateTime      @default(now())
  country      String?       // "AR", "US", "ES"
  city         String?       // "Buenos Aires"
  region       String?       // "B" (código de provincia)
  userAgent    String?       // User-Agent completo del browser
  device       String?       // "Desktop" | "Mobile" | "Tablet"
  browser      String?       // "Chrome" | "Firefox" | "Safari" | ...
  referrer     String?       // URL de origen (LinkedIn, Google, etc.)
  pageViews    PageView[]
  sessions     ChatSession[]

  @@index([country])
  @@index([createdAt])
}

model PageView {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  path      String   // "/", "/chat", "/servicios/landing"
  title     String?  // Titulo de la pagina
  duration  Int?     // Segundos en la pagina (opcional)
  visitor   Visitor  @relation(fields: [visitorId], references: [id])
  visitorId String

  @@index([visitorId])
  @@index([path])
  @@index([createdAt])
}

model ChatSession {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  visitor   Visitor?  @relation(fields: [visitorId], references: [id])
  visitorId String?
  messages  Message[]

  @@index([visitorId])
}

model Message {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  role      String      // "user" | "assistant"
  content   String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String

  @@index([sessionId])
  @@index([createdAt])
}
